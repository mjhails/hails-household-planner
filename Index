<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hails Household Planner</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter:wght@400;500;600;700&display=swap');

  :root{
    --paper:#F6F2E9;
    --paper-raised:#FFFEFB;
    --ink:#262A33;
    --ink-soft:#5B5F6B;
    --ink-faint:#9C9C92;
    --line:#DCD5C5;
    --mike:#1D7A6E;
    --mike-soft:#E2F0EC;
    --mike-text:#0E5048;
    --wife:#B5562E;
    --wife-soft:#F7E5DA;
    --wife-text:#7A3719;
    --both:#A6822E;
    --both-soft:#F4ECD3;
    --both-text:#6B5219;
    --empty:#EFEAE0;
    --shadow: 0 1px 2px rgba(38,42,51,0.06), 0 1px 1px rgba(38,42,51,0.04);
  }

  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--paper);
    color:var(--ink);
    font-family:'Inter',system-ui,sans-serif;
    min-height:100vh;
    padding:20px 16px 70px;
  }

  .wrap{max-width:640px;margin:0 auto;}

  /* ---------- HEADER ---------- */
  header{
    margin-bottom:18px;
  }
  .title-block h1{
    font-family:'Fraunces',serif;
    font-weight:600;
    font-size:28px;
    margin:0 0 2px;
    letter-spacing:-0.01em;
  }
  .title-block .sub{
    font-size:13px;
    color:var(--ink-soft);
  }

  /* ---------- VIEW TOGGLE ---------- */
  .view-toggle{
    display:flex;
    background:var(--empty);
    border-radius:10px;
    padding:3px;
    margin:16px 0;
    gap:3px;
  }
  .view-toggle button{
    flex:1;
    font-family:'Inter',sans-serif;
    font-size:13px;
    font-weight:500;
    padding:8px 0;
    border-radius:8px;
    border:none;
    background:transparent;
    color:var(--ink-soft);
    cursor:pointer;
  }
  .view-toggle button.active{
    background:var(--paper-raised);
    color:var(--ink);
    box-shadow:var(--shadow);
  }

  /* ---------- DAY NAV ---------- */
  .day-nav{
    display:flex;
    align-items:center;
    justify-content:space-between;
    margin-bottom:14px;
  }
  .day-nav button{
    width:36px;height:36px;
    border-radius:50%;
    border:1px solid var(--line);
    background:var(--paper-raised);
    color:var(--ink);
    cursor:pointer;
    font-size:16px;
    display:flex;align-items:center;justify-content:center;
    flex-shrink:0;
  }
  .day-nav button:hover{background:var(--empty);}
  .day-nav button:disabled{opacity:0.35;cursor:default;}
  .day-title{
    text-align:center;
    flex:1;
  }
  .day-title .dname{
    font-family:'Fraunces',serif;
    font-weight:600;
    font-size:20px;
  }
  .day-title .ddate{
    font-size:12px;
    color:var(--ink-faint);
    margin-top:1px;
  }
  .day-title.today .dname{color:var(--both-text);}
  .today-pill{
    display:inline-block;
    font-size:10px;
    text-transform:uppercase;
    letter-spacing:0.05em;
    background:var(--both-soft);
    color:var(--both-text);
    padding:2px 8px;
    border-radius:20px;
    margin-top:4px;
  }

  /* ---------- ROUTINE CARDS (day view) ---------- */
  .routine-list{
    display:flex;
    flex-direction:column;
    gap:10px;
  }
  .routine-card{
    background:var(--paper-raised);
    border:1px solid var(--line);
    border-radius:14px;
    box-shadow:var(--shadow);
    padding:14px 16px;
    display:flex;
    align-items:center;
    gap:12px;
  }
  .routine-time{
    width:56px;
    flex-shrink:0;
    font-size:12.5px;
    font-weight:500;
    color:var(--ink-soft);
    line-height:1.3;
  }
  .routine-time.notime{color:var(--ink-faint);font-style:italic;font-weight:400;}
  .routine-main{
    flex:1;
    min-width:0;
  }
  .routine-name{
    font-weight:600;
    font-size:14.5px;
    margin-bottom:2px;
  }
  .routine-note{
    font-size:12.5px;
    color:var(--ink-soft);
  }
  .routine-meta{
    display:flex;
    gap:10px;
    margin-top:3px;
  }
  .routine-meta button{
    background:none;border:none;color:var(--ink-faint);
    font-size:11px;cursor:pointer;padding:0;text-decoration:underline;
  }
  .routine-meta button:hover{color:var(--wife-text);}
  .routine-card.skipped{
    opacity:0.55;
  }
  .skip-pill{
    flex-shrink:0;
    border-radius:20px;
    border:1px solid var(--line);
    background:var(--empty);
    color:var(--ink-faint);
    font-size:12.5px;
    font-weight:500;
    padding:7px 14px;
    white-space:nowrap;
  }
  .who-btn{
    flex-shrink:0;
    border-radius:20px;
    border:1px dashed var(--line);
    background:var(--empty);
    color:var(--ink-faint);
    font-size:12.5px;
    font-weight:500;
    cursor:pointer;
    padding:7px 14px;
    white-space:nowrap;
  }
  .who-btn.set{
    border-style:solid;
    border-width:1px;
  }
  .who-btn.mike{background:var(--mike-soft);color:var(--mike-text);border-color:var(--mike);}
  .who-btn.wife{background:var(--wife-soft);color:var(--wife-text);border-color:var(--wife);}
  .who-btn.both{background:var(--both-soft);color:var(--both-text);border-color:var(--both);}

  .empty-day{
    text-align:center;
    padding:30px 16px;
    color:var(--ink-faint);
    font-size:13.5px;
  }

  /* ---------- ADD ROW ---------- */
  .add-row{
    background:var(--paper-raised);
    border:1px solid var(--line);
    border-radius:14px;
    padding:12px 14px;
    margin-top:14px;
    display:flex;
    gap:8px;
    flex-wrap:wrap;
  }
  .add-row input{
    font-family:'Inter',sans-serif;
    font-size:13px;
    padding:8px 10px;
    border-radius:8px;
    border:1px solid var(--line);
    background:var(--paper);
    color:var(--ink);
  }
  .add-row input[type=text]{flex:1;min-width:140px;}
  .add-row input[type=time]{width:100px;}
  .add-row button{
    font-family:'Inter',sans-serif;
    font-size:13px;
    font-weight:500;
    padding:8px 14px;
    border-radius:8px;
    border:1px solid var(--ink);
    background:var(--ink);
    color:var(--paper-raised);
    cursor:pointer;
  }
  .add-row button:hover{opacity:0.88;}

  /* ---------- WEEK OVERVIEW ---------- */
  .week-overview{
    background:var(--paper-raised);
    border:1px solid var(--line);
    border-radius:14px;
    box-shadow:var(--shadow);
    overflow:hidden;
  }
  .ov-row{
    display:flex;
    border-bottom:1px solid var(--line);
  }
  .ov-row:last-child{border-bottom:none;}
  .ov-label{
    width:118px;
    flex-shrink:0;
    padding:10px 10px;
    font-size:12px;
    font-weight:600;
    border-right:1px solid var(--line);
    background:var(--paper);
    display:flex;
    align-items:center;
  }
  .ov-days{
    display:flex;
    flex:1;
    overflow-x:auto;
  }
  .ov-cell{
    flex:1;
    min-width:40px;
    border-right:1px solid var(--line);
    padding:8px 4px;
    text-align:center;
    cursor:pointer;
  }
  .ov-cell:last-child{border-right:none;}
  .ov-cell:hover{background:var(--empty);}
  .ov-dot{
    width:9px;height:9px;
    border-radius:50%;
    margin:0 auto;
    background:var(--empty);
    border:1px solid var(--line);
  }
  .ov-dot.mike{background:var(--mike);border-color:var(--mike);}
  .ov-dot.wife{background:var(--wife);border-color:var(--wife);}
  .ov-dot.both{background:var(--both);border-color:var(--both);}
  .ov-head{
    display:flex;
    border-bottom:1px solid var(--line);
    background:var(--paper);
  }
  .ov-head .ov-label{border-right:1px solid var(--line);background:var(--paper);}
  .ov-head .ov-cell{
    cursor:default;
    font-size:11px;
    font-weight:600;
    color:var(--ink-soft);
    padding:8px 4px;
  }
  .ov-head .ov-cell.today{color:var(--both-text);background:var(--both-soft);}

  /* ---------- ACTIONS ---------- */
  .actions{
    display:flex;
    gap:10px;
    margin-top:16px;
    flex-wrap:wrap;
  }
  .actions button{
    font-family:'Inter',sans-serif;
    font-size:12.5px;
    font-weight:500;
    padding:8px 12px;
    border-radius:8px;
    border:1px solid var(--line);
    background:var(--paper-raised);
    color:var(--ink);
    cursor:pointer;
  }
  .actions button:hover{background:var(--empty);}
  .save-status{
    font-size:12px;
    color:var(--ink-faint);
    align-self:center;
    margin-left:auto;
  }

  /* ---------- PICKER POPOVER ---------- */
  .picker-backdrop{
    position:fixed;inset:0;
    background:rgba(38,42,51,0.28);
    display:flex;align-items:center;justify-content:center;
    z-index:50;
    padding:20px;
  }
  .picker{
    background:var(--paper-raised);
    border-radius:14px;
    padding:18px;
    width:280px;
    max-width:100%;
    box-shadow:0 10px 30px rgba(38,42,51,0.25);
  }
  .picker h3{
    font-family:'Fraunces',serif;
    font-size:17px;
    font-weight:600;
    margin:0 0 2px;
  }
  .picker .picker-sub{
    font-size:12px;
    color:var(--ink-soft);
    margin:0 0 14px;
  }
  .picker-opt{
    display:flex;
    align-items:center;
    gap:10px;
    width:100%;
    padding:10px 12px;
    margin-bottom:6px;
    border-radius:9px;
    border:1px solid var(--line);
    background:var(--empty);
    cursor:pointer;
    font-size:14px;
    font-weight:500;
    color:var(--ink);
    text-align:left;
  }
  .picker-opt .dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;}
  .picker-opt.opt-mike .dot{background:var(--mike);}
  .picker-opt.opt-wife .dot{background:var(--wife);}
  .picker-opt.opt-both .dot{background:var(--both);}
  .picker-opt.opt-clear .dot{background:var(--ink-faint);}
  .picker-opt:hover{border-color:var(--ink-faint);}
  .picker-note input{
    width:100%;
    font-family:'Inter',sans-serif;
    font-size:13px;
    padding:8px 10px;
    border-radius:8px;
    border:1px solid var(--line);
    background:var(--empty);
    margin-bottom:8px;
  }
  .picker-close{
    width:100%;
    text-align:center;
    padding:8px;
    font-size:13px;
    color:var(--ink-faint);
    background:none;
    border:none;
    cursor:pointer;
    margin-top:4px;
  }

  /* ---------- ROW EDIT POPOVER ---------- */
  .picker label.field-label{
    display:block;
    font-size:11.5px;
    color:var(--ink-soft);
    margin:10px 0 4px;
  }
  .picker .field-row{
    display:flex;
    gap:8px;
  }
  .picker .field-row input{
    flex:1;
    font-family:'Inter',sans-serif;
    font-size:13px;
    padding:7px 8px;
    border-radius:8px;
    border:1px solid var(--line);
    background:var(--empty);
  }
  .picker .skip-list{
    margin-top:10px;
    max-height:120px;
    overflow-y:auto;
  }
  .skip-item{
    display:flex;
    justify-content:space-between;
    align-items:center;
    font-size:12px;
    color:var(--ink-soft);
    padding:5px 0;
    border-bottom:1px solid var(--line);
  }
  .skip-item:last-child{border-bottom:none;}
  .skip-item button{
    background:none;border:none;color:var(--wife-text);
    font-size:11px;cursor:pointer;text-decoration:underline;
  }
  .picker .btn-row{
    display:flex;
    gap:8px;
    margin-top:10px;
  }
  .picker .btn-row button{
    flex:1;
    font-family:'Inter',sans-serif;
    font-size:12.5px;
    font-weight:500;
    padding:8px 0;
    border-radius:8px;
    border:1px solid var(--line);
    background:var(--empty);
    color:var(--ink);
    cursor:pointer;
  }
  .picker .btn-row button.primary{
    background:var(--ink);
    color:var(--paper-raised);
    border-color:var(--ink);
  }
  .picker .btn-row button.danger{
    color:var(--wife-text);
    border-color:var(--wife);
  }

  /* ---------- LEGEND ---------- */
  .legend{
    display:flex;
    gap:16px;
    flex-wrap:wrap;
    margin-top:16px;
    font-size:12.5px;
    color:var(--ink-soft);
  }
  .legend span{display:inline-flex;align-items:center;gap:6px;}
  .legend .dot{width:9px;height:9px;border-radius:50%;}
  .legend .dot.mike{background:var(--mike);}
  .legend .dot.wife{background:var(--wife);}
  .legend .dot.both{background:var(--both);}

  .footnote{
    margin-top:16px;
    font-size:11.5px;
    color:var(--ink-faint);
    text-align:center;
  }

  .hidden{display:none !important;}
</style>
</head>
<body>
<div class="wrap">

  <header>
    <div class="title-block">
      <h1>The weekly board</h1>
      <div class="sub">Who's doing what — Mike &amp; Steph</div>
    </div>
  </header>

  <div class="view-toggle">
    <button id="tab-day" class="active">Day</button>
    <button id="tab-week">Week overview</button>
  </div>

  <!-- DAY VIEW -->
  <div id="day-view">
    <div class="day-nav">
      <button id="prev-day" aria-label="Previous day">&#8249;</button>
      <div class="day-title" id="day-title">
        <div class="dname" id="day-dname">Monday</div>
        <div class="ddate" id="day-ddate">1 Jan</div>
      </div>
      <button id="next-day" aria-label="Next day">&#8250;</button>
    </div>

    <div class="routine-list" id="routine-list"></div>

    <div class="add-row">
      <input type="text" id="new-routine-name" placeholder="Add a routine, e.g. Bath time">
      <input type="time" id="new-routine-time">
      <button id="add-routine-btn">Add</button>
    </div>
  </div>

  <!-- WEEK VIEW -->
  <div id="week-view" class="hidden">
    <div class="week-overview" id="week-overview"></div>
  </div>

  <div class="actions">
    <button id="load-template-btn">Load saved template</button>
    <button id="save-template-btn">Save week as template</button>
    <span class="save-status" id="save-status"></span>
  </div>

  <div class="legend">
    <span><span class="dot mike"></span>Mike</span>
    <span><span class="dot wife"></span>Steph</span>
    <span><span class="dot both"></span>Both / shared</span>
  </div>

  <p class="footnote">Separate from your joint calendar — just for the weekly back-and-forth. Tap a routine to assign it.</p>
</div>

<div id="picker-root"></div>

<script type="module">
  // ---- Firebase setup ----
  // Paste your existing Firebase project config below (same one used for
  // the Hails vs Palmers World Cup Sweepstake site). This planner uses its
  // own collection ("household-planner") so it won't touch any of your
  // other Firestore data.
  import { initializeApp } from 'https://www.gstatic.com/firebasejs/12.15.0/firebase-app.js';
  import {
    getFirestore, doc, getDoc, setDoc, onSnapshot
  } from 'https://www.gstatic.com/firebasejs/12.15.0/firebase-firestore.js';

  const firebaseConfig = {
    apiKey: "PASTE_YOUR_API_KEY",
    authDomain: "PASTE_YOUR_AUTH_DOMAIN",
    projectId: "PASTE_YOUR_PROJECT_ID",
    storageBucket: "PASTE_YOUR_STORAGE_BUCKET",
    messagingSenderId: "PASTE_YOUR_SENDER_ID",
    appId: "PASTE_YOUR_APP_ID"
  };

  const fbApp = initializeApp(firebaseConfig);
  const db = getFirestore(fbApp);

  if(firebaseConfig.apiKey === "PASTE_YOUR_API_KEY"){
    window.addEventListener('DOMContentLoaded', function(){
      var warn = document.createElement('div');
      warn.style.cssText = 'background:#F7E5DA;color:#7A3719;padding:10px 16px;border-radius:10px;font-size:13px;margin-bottom:14px;font-family:Inter,sans-serif;';
      warn.textContent = 'Firebase config not set yet — open index.html and paste in your project keys near the top of the file.';
      document.body.insertBefore(warn, document.body.firstChild);
    });
  }

  // Expose a tiny storage shim with the same shape as the old in-chat
  // storage API, so the rest of the app doesn't need to change.
  // Collection: household-planner
  //   doc "rows-config"      -> { value: JSON string of rows array }
  //   doc "assignments-all"  -> { value: JSON string of assignments map }
  //   doc "week-template"    -> { value: JSON string of saved template }
  window.firestoreStorage = {
    async get(key){
      const ref = doc(db, 'household-planner', key);
      const snap = await getDoc(ref);
      if(!snap.exists()) return null;
      return { key: key, value: snap.data().value };
    },
    async set(key, value){
      const ref = doc(db, 'household-planner', key);
      await setDoc(ref, { value: value, updatedAt: Date.now() });
      return { key: key, value: value };
    },
    // live: call back with the latest value whenever it changes,
    // including changes made from your wife's device.
    listen(key, callback){
      const ref = doc(db, 'household-planner', key);
      return onSnapshot(ref, function(snap){
        if(snap.exists()){ callback(snap.data().value); }
      });
    }
  };

  window.dispatchEvent(new Event('firebase-ready'));
</script>

<script>
(function(){

  var PEOPLE_LABELS = { mike: 'Mike', wife: 'Steph', both: 'Both' };
  var DAY_NAMES = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];
  var DAY_SHORT = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];

  var DEFAULT_ROWS = [
    { id: 'r1', name: 'Wake & feed Harvey', time: '07:00' },
    { id: 'r2', name: 'Amelia breakfast', time: '07:30' },
    { id: 'r3', name: 'School / nursery drop-off', time: '08:30' },
    { id: 'r4', name: 'School pick-up', time: '15:15' },
    { id: 'r5', name: 'Cooking tea', time: '17:30' },
    { id: 'r6', name: 'Gym slot', time: '' },
    { id: 'r7', name: 'Bedtime / evening routine', time: '19:00' }
  ];

  var state = {
    activeTab: 'day',
    dayOffset: 0,      // days from today, for day view
    weekOffset: 0,     // weeks from this week, for week view
    rows: DEFAULT_ROWS.map(function(r){ return { id: r.id, name: r.name, time: r.time || '', skips: [] }; }),
    assignments: {}    // key: "weekKey:rowId:dayIdx" -> {who, note}
  };

  var activePicker = null;

  function pad(n){ return n < 10 ? '0'+n : ''+n; }

  function getMonday(d){
    var date = new Date(d);
    var day = date.getDay();
    var diff = (day === 0 ? -6 : 1) - day;
    date.setDate(date.getDate() + diff);
    date.setHours(0,0,0,0);
    return date;
  }

  function weekKeyForDate(d){
    var m = getMonday(d);
    return m.getFullYear()+'-'+pad(m.getMonth()+1)+'-'+pad(m.getDate());
  }

  function weekKeyFor(offset){
    var base = getMonday(new Date());
    base.setDate(base.getDate() + offset*7);
    return base.getFullYear()+'-'+pad(base.getMonth()+1)+'-'+pad(base.getDate());
  }

  function weekDatesFor(offset){
    var base = getMonday(new Date());
    base.setDate(base.getDate() + offset*7);
    var arr = [];
    for(var i=0;i<7;i++){
      var d = new Date(base);
      d.setDate(d.getDate()+i);
      arr.push(d);
    }
    return arr;
  }

  function currentDayDate(){
    var d = new Date();
    d.setHours(0,0,0,0);
    d.setDate(d.getDate() + state.dayOffset);
    return d;
  }

  function dayIndexOf(d){
    var day = d.getDay();
    return day === 0 ? 6 : day - 1;
  }

  function isSameDate(a,b){
    return a.getFullYear()===b.getFullYear() && a.getMonth()===b.getMonth() && a.getDate()===b.getDate();
  }

  function assignKey(weekKey, rowId, dayIdx){
    return weekKey+':'+rowId+':'+dayIdx;
  }

  function formatTime12(t){
    if(!t) return '';
    var parts = t.split(':');
    var h = parseInt(parts[0],10);
    var m = parts[1];
    var suffix = h >= 12 ? 'pm' : 'am';
    var h12 = h % 12;
    if(h12 === 0) h12 = 12;
    return h12 + (m !== '00' ? ':'+m : '') + suffix;
  }

  function setStatus(msg){
    var el = document.getElementById('save-status');
    el.textContent = msg;
    if(msg){
      setTimeout(function(){ if(el.textContent === msg) el.textContent=''; }, 2200);
    }
  }

  function isoDate(d){
    return d.getFullYear()+'-'+pad(d.getMonth()+1)+'-'+pad(d.getDate());
  }

  function isSkipped(row, dateObj){
    if(!row.skips || !row.skips.length) return false;
    var iso = isoDate(dateObj);
    return row.skips.some(function(s){
      return iso >= s.from && iso <= s.to;
    });
  }

  function activeSkipLabel(row, dateObj){
    if(!row.skips) return '';
    var iso = isoDate(dateObj);
    var hit = row.skips.find(function(s){ return iso >= s.from && iso <= s.to; });
    return hit ? (hit.label || 'Skipped') : '';
  }

  function escapeHtml(str){
    var div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function sortedRows(){
    return state.rows.slice().sort(function(a,b){
      if(!a.time && !b.time) return 0;
      if(!a.time) return 1;
      if(!b.time) return -1;
      return a.time.localeCompare(b.time);
    });
  }

  // ---------- STORAGE (Firestore) ----------
  async function loadAll(){
    try{
      var rowsRes = await window.firestoreStorage.get('rows-config');
      if(rowsRes && rowsRes.value){
        state.rows = JSON.parse(rowsRes.value);
        state.rows.forEach(function(r){ if(!r.skips) r.skips = []; });
      }
    }catch(e){ console.error('load rows failed', e); }

    try{
      var asgRes = await window.firestoreStorage.get('assignments-all');
      if(asgRes && asgRes.value){ state.assignments = JSON.parse(asgRes.value); }
    }catch(e){ console.error('load assignments failed', e); }
  }

  var suppressNextRowsEcho = false;
  var suppressNextAssignmentsEcho = false;

  function startLiveSync(){
    // When Steph's device (or yours, from elsewhere) saves a change,
    // pick it up here and re-render — no refresh needed.
    window.firestoreStorage.listen('rows-config', function(value){
      if(suppressNextRowsEcho){ suppressNextRowsEcho = false; return; }
      try{
        state.rows = JSON.parse(value);
        state.rows.forEach(function(r){ if(!r.skips) r.skips = []; });
        renderAll();
      }catch(e){ console.error(e); }
    });
    window.firestoreStorage.listen('assignments-all', function(value){
      if(suppressNextAssignmentsEcho){ suppressNextAssignmentsEcho = false; return; }
      try{
        state.assignments = JSON.parse(value);
        renderAll();
      }catch(e){ console.error(e); }
    });
  }

  async function saveRows(){
    try{
      suppressNextRowsEcho = true;
      await window.firestoreStorage.set('rows-config', JSON.stringify(state.rows));
    }catch(e){ console.error('save rows failed', e); setStatus('Could not save — check connection'); }
  }

  async function saveAssignments(){
    try{
      suppressNextAssignmentsEcho = true;
      await window.firestoreStorage.set('assignments-all', JSON.stringify(state.assignments));
      setStatus('Saved');
    }catch(e){
      console.error('save assignments failed', e);
      setStatus('Could not save — check connection');
    }
  }

  async function saveTemplate(){
    var weekKey = weekKeyFor(state.weekOffset);
    var tpl = {};
    state.rows.forEach(function(row){
      DAY_SHORT.forEach(function(_, dayIdx){
        var k = assignKey(weekKey, row.id, dayIdx);
        if(state.assignments[k]){ tpl[row.id+':'+dayIdx] = state.assignments[k]; }
      });
    });
    try{
      await window.firestoreStorage.set('week-template', JSON.stringify({ rows: state.rows, assignments: tpl }));
      setStatus('Template saved');
    }catch(e){ console.error(e); setStatus('Could not save template'); }
  }

  async function loadTemplate(){
    try{
      var res = await window.firestoreStorage.get('week-template');
      if(!res || !res.value){ setStatus('No template saved yet'); return; }
      var tpl = JSON.parse(res.value);
      var weekKey = weekKeyFor(state.weekOffset);
      if(tpl.rows) state.rows = tpl.rows;
      Object.keys(tpl.assignments || {}).forEach(function(rowDayKey){
        var parts = rowDayKey.split(':');
        var rowId = parts[0], dayIdx = parts[1];
        state.assignments[assignKey(weekKey, rowId, dayIdx)] = tpl.assignments[rowDayKey];
      });
      await saveRows();
      await saveAssignments();
      renderAll();
      setStatus('Template loaded into this week');
    }catch(e){ console.error(e); setStatus('Could not load template'); }
  }

  // ---------- RENDER: DAY VIEW ----------
  function renderDayView(){
    var d = currentDayDate();
    var dayIdx = dayIndexOf(d);
    var weekKey = weekKeyForDate(d);
    var today = new Date();
    today.setHours(0,0,0,0);
    var isToday = isSameDate(d, today);

    document.getElementById('day-dname').textContent = DAY_NAMES[dayIdx];
    document.getElementById('day-ddate').innerHTML = d.getDate()+' '+d.toLocaleString('en-GB',{month:'short'}) + (isToday ? '<br><span class="today-pill">Today</span>' : '');
    document.getElementById('day-title').className = 'day-title' + (isToday ? ' today' : '');

    var list = document.getElementById('routine-list');
    list.innerHTML = '';

    var rows = sortedRows();
    if(rows.length === 0){
      list.innerHTML = '<div class="empty-day">No routines yet — add your first one below.</div>';
      return;
    }

    rows.forEach(function(row){
      var k = assignKey(weekKey, row.id, dayIdx);
      var entry = state.assignments[k];
      var skipped = isSkipped(row, d);

      var card = document.createElement('div');
      card.className = 'routine-card' + (skipped ? ' skipped' : '');

      var timeHtml = row.time
        ? '<div class="routine-time">'+formatTime12(row.time)+'</div>'
        : '<div class="routine-time notime">any time</div>';

      var metaHtml =
        '<div class="routine-meta">' +
          '<button class="edit-time-btn" data-row="'+row.id+'">edit time</button>' +
          '<button class="manage-skip-btn" data-row="'+row.id+'">'+(skipped ? 'manage skip' : 'skip dates')+'</button>' +
        '</div>';

      var mainHtml =
        '<div class="routine-main">' +
          '<div class="routine-name">'+escapeHtml(row.name)+'</div>' +
          (skipped
            ? '<div class="routine-note">'+escapeHtml(activeSkipLabel(row, d))+'</div>'
            : (entry && entry.note ? '<div class="routine-note">'+escapeHtml(entry.note)+'</div>' : '')) +
          metaHtml +
        '</div>';

      var rightHtml;
      if(skipped){
        rightHtml = '<div class="skip-pill">Skipped</div>';
      }else{
        var whoClass = 'who-btn';
        var whoLabel = '+ assign';
        if(entry && entry.who){
          whoClass += ' set ' + entry.who;
          whoLabel = PEOPLE_LABELS[entry.who] || entry.who;
        }
        rightHtml = '<button class="'+whoClass+'" data-row="'+row.id+'" data-day="'+dayIdx+'">'+whoLabel+'</button>';
      }

      card.innerHTML = timeHtml + mainHtml + rightHtml;
      list.appendChild(card);
    });
  }

  // ---------- RENDER: WEEK OVERVIEW ----------
  function renderWeekView(){
    var dates = weekDatesFor(state.weekOffset);
    var weekKey = weekKeyFor(state.weekOffset);
    var today = new Date();
    today.setHours(0,0,0,0);
    var thisWeekKey = weekKeyFor(0);

    var ov = document.getElementById('week-overview');
    ov.innerHTML = '';

    var head = document.createElement('div');
    head.className = 'ov-head';
    head.innerHTML = '<div class="ov-label">'+fmtWeekRange(dates)+'</div>';
    dates.forEach(function(d, idx){
      var isToday = weekKey === thisWeekKey && isSameDate(d, today);
      var cell = document.createElement('div');
      cell.className = 'ov-cell' + (isToday ? ' today' : '');
      cell.textContent = DAY_SHORT[idx];
      head.appendChild(cell);
    });
    ov.appendChild(head);

    var rows = sortedRows();
    rows.forEach(function(row){
      var rowEl = document.createElement('div');
      rowEl.className = 'ov-row';
      rowEl.innerHTML = '<div class="ov-label">'+escapeHtml(row.name)+(row.time ? '<br><span style="color:var(--ink-faint);font-weight:400;font-size:11px;">'+formatTime12(row.time)+'</span>' : '')+'</div>';

      var daysWrap = document.createElement('div');
      daysWrap.className = 'ov-days';

      dates.forEach(function(d, dayIdx){
        var k = assignKey(weekKey, row.id, dayIdx);
        var entry = state.assignments[k];
        var cell = document.createElement('div');
        cell.className = 'ov-cell';
        cell.setAttribute('data-row', row.id);
        cell.setAttribute('data-dayoffset', dayOffsetFor(d));
        var skipped = isSkipped(row, d);
        var dotClass = 'ov-dot' + (skipped ? '' : (entry && entry.who ? ' '+entry.who : ''));
        cell.innerHTML = skipped
          ? '<div style="font-size:10px;color:var(--ink-faint);">&times;</div>'
          : '<div class="'+dotClass+'"></div>';
        daysWrap.appendChild(cell);
      });

      rowEl.appendChild(daysWrap);
      ov.appendChild(rowEl);
    });
  }

  function fmtWeekRange(dates){
    var fmt = function(d){ return d.getDate()+' '+d.toLocaleString('en-GB',{month:'short'}); };
    return fmt(dates[0])+' \u2013 '+fmt(dates[6]);
  }

  function dayOffsetFor(d){
    var today = new Date();
    today.setHours(0,0,0,0);
    var dd = new Date(d);
    dd.setHours(0,0,0,0);
    return Math.round((dd - today) / 86400000);
  }

  function renderAll(){
    renderDayView();
    renderWeekView();
  }

  // ---------- PICKER ----------
  function openPicker(rowId, dayIdx, weekKeyOverride){
    activePicker = { rowId: rowId, dayIdx: dayIdx, weekKey: weekKeyOverride || weekKeyForDate(currentDayDate()) };
    var row = state.rows.find(function(r){ return r.id === rowId; });
    var k = assignKey(activePicker.weekKey, rowId, dayIdx);
    var existing = state.assignments[k] || {};

    var root = document.getElementById('picker-root');
    var timeNote = row && row.time ? ' &middot; '+formatTime12(row.time) : '';
    root.innerHTML =
      '<div class="picker-backdrop" id="picker-backdrop">'+
        '<div class="picker">'+
          '<h3>'+escapeHtml(row ? row.name : '')+'</h3>'+
          '<p class="picker-sub">'+DAY_NAMES[dayIdx]+timeNote+'</p>'+
          '<button class="picker-opt opt-mike" data-who="mike"><span class="dot"></span>Mike</button>'+
          '<button class="picker-opt opt-wife" data-who="wife"><span class="dot"></span>Steph</button>'+
          '<button class="picker-opt opt-both" data-who="both"><span class="dot"></span>Both / shared</button>'+
          '<div class="picker-note">'+
            '<input type="text" id="picker-note-input" placeholder="Optional note, e.g. running late" value="'+escapeHtml(existing.note || '')+'">'+
          '</div>'+
          '<button class="picker-opt opt-clear" data-who="clear"><span class="dot"></span>Clear</button>'+
          '<button class="picker-close" id="picker-close">Cancel</button>'+
        '</div>'+
      '</div>';

    root.querySelectorAll('.picker-opt').forEach(function(b){
      b.addEventListener('click', function(){ handlePickerChoice(b.getAttribute('data-who')); });
    });
    document.getElementById('picker-close').addEventListener('click', closePicker);
    document.getElementById('picker-backdrop').addEventListener('click', function(e){
      if(e.target.id === 'picker-backdrop') closePicker();
    });
  }

  function closePicker(){
    document.getElementById('picker-root').innerHTML = '';
    activePicker = null;
  }

  // ---------- TIME EDITOR ----------
  function openTimeEditor(rowId){
    var row = state.rows.find(function(r){ return r.id === rowId; });
    if(!row) return;
    var root = document.getElementById('picker-root');
    root.innerHTML =
      '<div class="picker-backdrop" id="picker-backdrop">'+
        '<div class="picker">'+
          '<h3>'+escapeHtml(row.name)+'</h3>'+
          '<p class="picker-sub">Set the usual time for this routine</p>'+
          '<label class="field-label" for="time-edit-input">Time</label>'+
          '<div class="field-row"><input type="time" id="time-edit-input" value="'+(row.time||'')+'"></div>'+
          '<div class="btn-row">'+
            '<button id="time-edit-save" class="primary">Save</button>'+
            '<button id="time-edit-remove" class="danger">Remove row</button>'+
          '</div>'+
          '<button class="picker-close" id="picker-close">Cancel</button>'+
        '</div>'+
      '</div>';

    document.getElementById('time-edit-save').addEventListener('click', function(){
      row.time = document.getElementById('time-edit-input').value || '';
      saveRows();
      closePicker();
      renderAll();
    });
    document.getElementById('time-edit-remove').addEventListener('click', function(){
      if(confirm('Remove "'+row.name+'" from the board entirely? This deletes it from every week.')){
        state.rows = state.rows.filter(function(r){ return r.id !== rowId; });
        saveRows();
        closePicker();
        renderAll();
      }
    });
    document.getElementById('picker-close').addEventListener('click', closePicker);
    document.getElementById('picker-backdrop').addEventListener('click', function(e){
      if(e.target.id === 'picker-backdrop') closePicker();
    });
  }

  // ---------- SKIP MANAGER ----------
  function openSkipManager(rowId){
    var row = state.rows.find(function(r){ return r.id === rowId; });
    if(!row) return;
    if(!row.skips) row.skips = [];
    var todayIso = isoDate(currentDayDate());

    renderSkipManager(row, todayIso);
  }

  function renderSkipManager(row, todayIso){
    var root = document.getElementById('picker-root');
    var listHtml = row.skips.length
      ? '<div class="skip-list">' + row.skips.map(function(s, i){
          var rangeLabel = s.from === s.to ? fmtIsoShort(s.from) : (fmtIsoShort(s.from)+' \u2013 '+fmtIsoShort(s.to));
          return '<div class="skip-item"><span>'+escapeHtml(s.label || 'Skipped')+' &middot; '+rangeLabel+'</span><button data-idx="'+i+'">remove</button></div>';
        }).join('') + '</div>'
      : '<p class="picker-sub" style="margin-top:10px;">No skips set for this routine yet.</p>';

    root.innerHTML =
      '<div class="picker-backdrop" id="picker-backdrop">'+
        '<div class="picker">'+
          '<h3>'+escapeHtml(row.name)+'</h3>'+
          '<p class="picker-sub">Skip this routine for a day or a date range — handy for school holidays</p>'+
          '<label class="field-label" for="skip-from">From</label>'+
          '<div class="field-row"><input type="date" id="skip-from" value="'+todayIso+'"></div>'+
          '<label class="field-label" for="skip-to">To (same as From for a single day)</label>'+
          '<div class="field-row"><input type="date" id="skip-to" value="'+todayIso+'"></div>'+
          '<label class="field-label" for="skip-label">Label (optional)</label>'+
          '<div class="field-row"><input type="text" id="skip-label" placeholder="e.g. Half term"></div>'+
          '<div class="btn-row"><button id="skip-add" class="primary">Add skip</button></div>'+
          listHtml +
          '<button class="picker-close" id="picker-close">Close</button>'+
        '</div>'+
      '</div>';

    document.getElementById('skip-add').addEventListener('click', function(){
      var from = document.getElementById('skip-from').value;
      var to = document.getElementById('skip-to').value || from;
      var label = document.getElementById('skip-label').value.trim();
      if(!from){ return; }
      if(to < from){ to = from; }
      row.skips.push({ from: from, to: to, label: label });
      saveRows();
      renderSkipManager(row, todayIso);
      renderAll();
    });

    root.querySelectorAll('.skip-item button').forEach(function(b){
      b.addEventListener('click', function(){
        var idx = parseInt(b.getAttribute('data-idx'),10);
        row.skips.splice(idx,1);
        saveRows();
        renderSkipManager(row, todayIso);
        renderAll();
      });
    });

    document.getElementById('picker-close').addEventListener('click', closePicker);
    document.getElementById('picker-backdrop').addEventListener('click', function(e){
      if(e.target.id === 'picker-backdrop') closePicker();
    });
  }

  function fmtIsoShort(iso){
    var parts = iso.split('-');
    var d = new Date(parseInt(parts[0],10), parseInt(parts[1],10)-1, parseInt(parts[2],10));
    return d.getDate()+' '+d.toLocaleString('en-GB',{month:'short'});
  }

  async function handlePickerChoice(who){
    if(!activePicker) return;
    var k = assignKey(activePicker.weekKey, activePicker.rowId, activePicker.dayIdx);
    var noteInput = document.getElementById('picker-note-input');
    var note = noteInput ? noteInput.value.trim() : '';

    if(who === 'clear'){ delete state.assignments[k]; }
    else{ state.assignments[k] = { who: who, note: note }; }

    closePicker();
    renderAll();
    await saveAssignments();
  }

  // ---------- TABS ----------
  function setTab(tab){
    state.activeTab = tab;
    document.getElementById('tab-day').classList.toggle('active', tab === 'day');
    document.getElementById('tab-week').classList.toggle('active', tab === 'week');
    document.getElementById('day-view').classList.toggle('hidden', tab !== 'day');
    document.getElementById('week-view').classList.toggle('hidden', tab !== 'week');
    if(tab === 'week'){
      // keep week view's visible week aligned with whatever day is showing
      var d = currentDayDate();
      var todayMonday = getMonday(new Date());
      var thisMonday = getMonday(d);
      state.weekOffset = Math.round((thisMonday - todayMonday) / (7*86400000));
      renderWeekView();
    }
  }

  // ---------- EVENTS ----------
  document.getElementById('tab-day').addEventListener('click', function(){ setTab('day'); });
  document.getElementById('tab-week').addEventListener('click', function(){ setTab('week'); });

  document.getElementById('prev-day').addEventListener('click', function(){
    state.dayOffset -= 1;
    renderDayView();
  });
  document.getElementById('next-day').addEventListener('click', function(){
    state.dayOffset += 1;
    renderDayView();
  });

  document.getElementById('routine-list').addEventListener('click', function(e){
    var btn = e.target.closest('.who-btn');
    if(btn){
      openPicker(btn.getAttribute('data-row'), parseInt(btn.getAttribute('data-day'),10), weekKeyForDate(currentDayDate()));
      return;
    }
    var editBtn = e.target.closest('.edit-time-btn');
    if(editBtn){
      openTimeEditor(editBtn.getAttribute('data-row'));
      return;
    }
    var skipBtn = e.target.closest('.manage-skip-btn');
    if(skipBtn){
      openSkipManager(skipBtn.getAttribute('data-row'));
      return;
    }
  });

  document.getElementById('week-overview').addEventListener('click', function(e){
    var cell = e.target.closest('.ov-cell[data-row]');
    if(cell){
      state.dayOffset = parseInt(cell.getAttribute('data-dayoffset'),10);
      setTab('day');
    }
  });

  document.getElementById('add-routine-btn').addEventListener('click', function(){
    var input = document.getElementById('new-routine-name');
    var timeInput = document.getElementById('new-routine-time');
    var name = input.value.trim();
    if(!name) return;
    var id = 'r' + Date.now();
    state.rows.push({ id: id, name: name, time: timeInput.value || '', skips: [] });
    input.value = '';
    timeInput.value = '';
    saveRows();
    renderAll();
  });
  document.getElementById('new-routine-name').addEventListener('keydown', function(e){
    if(e.key === 'Enter'){ document.getElementById('add-routine-btn').click(); }
  });

  document.getElementById('save-template-btn').addEventListener('click', saveTemplate);
  document.getElementById('load-template-btn').addEventListener('click', loadTemplate);

  // ---------- INIT ----------
  function startApp(){
    renderAll();
    loadAll().then(function(){
      renderAll();
      startLiveSync();
    });
  }

  if(window.firestoreStorage){
    startApp();
  }else{
    setStatus('Connecting…');
    window.addEventListener('firebase-ready', startApp, { once: true });
  }

})();
</script>
</body>
</html>
